set.seed(42)  # For reproducibility
train_index <- createDataPartition(model_data$cyber_type,
p = 0.70,
list = FALSE,
times = 1)
# Drop the incident_num ID column before splitting
model_data_clean <- model_data %>% select(-incident_num)
train_data <- model_data_clean[train_index, ]
test_data  <- model_data_clean[-train_index, ]
cat("\n===== SPLIT VERIFICATION =====\n")
cat(sprintf("\nFull data:   n = %d\n", nrow(model_data_clean)))
print(prop.table(table(model_data_clean$cyber_type)))
