)
cat("\nCollapsed damage_type distribution:\n")
print(table(dcid$damage_type_collapsed))
model_data <- dcid %>%
select(
# DV
cyber_type,
# Predictors
method_cat,
obj_achievement,
concession,
third_party,
damage_type_collapsed,
crit_infra_collapsed,
supply_chain,
ransomware,
# Keep ID for reference (will drop before modeling)
incident_num
)
cat("\nFinal modeling dataset structure:\n")
str(model_data)
cat("\nMissing values:\n")
print(colSums(is.na(model_data)))
cat("\nAll factor levels:\n")
model_data %>%
select(where(is.factor)) %>%
sapply(levels) %>%
print()
write_csv(model_data, "01_data/processed/dcid_model_ready.csv")
getwd()
write_csv(model_data, "01_data/02_processed/dcid_model_ready.csv")
cat("\nSaved: 01_data/02_processed/dcid_model_ready.csv\n")
cat("Script 03 complete.\n")
