library(tidyverse)
library(caret)
library(pROC)
reload_factors <- function(df) {
df %>% mutate(
cyber_type            = factor(cyber_type, levels = c("Tactical", "Strategic")),
method_cat            = factor(method_cat),
obj_achievement       = factor(obj_achievement),
concession            = factor(concession),
third_party           = factor(third_party),
damage_type_collapsed = factor(damage_type_collapsed),
crit_infra_collapsed  = factor(crit_infra_collapsed),
supply_chain          = factor(supply_chain),
ransomware            = factor(ransomware)
)
}
if (!exists("train_data")) {
train_data <- read_csv("01_data/processed/dcid_train.csv", show_col_types = FALSE) %>% reload_factors()
test_data  <- read_csv("01_data/processed/dcid_test.csv",  show_col_types = FALSE) %>% reload_factors()
cat("Loaded train/test from CSV.\n")
}
logit_model <- glm(cyber_type ~ method_cat + obj_achievement + concession +
third_party + damage_type_collapsed + crit_infra_collapsed +
supply_chain + ransomware,
data = train_data,
family = binomial(link = "logit"))
cat("\n===== LOGISTIC REGRESSION SUMMARY =====\n")
summary(logit_model)
# Odds ratios
cat("\n--- Odds Ratios ---\n")
or_table <- data.frame(
Variable     = names(coef(logit_model)),
Coefficient  = coef(logit_model),
Odds_Ratio   = exp(coef(logit_model)),
CI_Lower     = exp(confint.default(logit_model)[, 1]),
CI_Upper     = exp(confint.default(logit_model)[, 2]),
P_Value      = summary(logit_model)$coefficients[, 4]
)
print(or_table, digits = 3)
write_csv(or_table, "03_outputs/02_tables/logit_odds_ratios.csv")
write_csv(or_table, "03_outputs/logit_odds_ratios.csv")
test_probs <- predict(logit_model, newdata = test_data, type = "response")
test_pred  <- factor(ifelse(test_probs > 0.5, "Strategic", "Tactical"),
levels = c("Tactical", "Strategic"))
cm_logit <- confusionMatrix(test_pred, test_data$cyber_type,
positive = "Strategic")
cat("\n===== CONFUSION MATRIX =====\n")
print(cm_logit)
roc_logit <- roc(test_data$cyber_type, test_probs,
levels = c("Tactical", "Strategic"),
direction = "<")
cat(sprintf("\nAUC: %.4f\n", auc(roc_logit)))
png("03_outputs/figures/model_diagnostics/roc_logit.png", width = 600, height = 500)
plot(roc_logit, main = "ROC Curve — Logistic Regression",
col = "#2C3E50", lwd = 2, print.auc = TRUE)
png("03_outputs/figures/model_diagnostics/roc_logit.png", width = 600, height = 500)
plot(roc_logit, main = "ROC Curve — Logistic Regression",
col = "#2C3E50", lwd = 2, print.auc = TRUE)
dev.off()
saveRDS(logit_model, "03_outputs/models/logit_model.rds")
logit_results <- list(
model       = logit_model,
predictions = test_pred,
probs       = test_probs,
confusion   = cm_logit,
roc         = roc_logit,
auc         = as.numeric(auc(roc_logit)),
metrics     = data.frame(
Model     = "Logistic Regression",
Accuracy  = cm_logit$overall["Accuracy"],
Precision = cm_logit$byClass["Precision"],
Recall    = cm_logit$byClass["Recall"],
F1        = cm_logit$byClass["F1"],
AUC       = as.numeric(auc(roc_logit))
)
)
saveRDS(logit_results, "03_outputs/models/logit_results.rds")
cat("\nSaved: logit_model.rds, logit_results.rds\n")
cat("Script 05 complete.\n")
library(tidyverse)
library(caret)
library(rpart)
library(rpart.plot)
library(pROC)
reload_factors <- function(df) {
df %>% mutate(
cyber_type            = factor(cyber_type, levels = c("Tactical", "Strategic")),
method_cat            = factor(method_cat),
obj_achievement       = factor(obj_achievement),
concession            = factor(concession),
third_party           = factor(third_party),
damage_type_collapsed = factor(damage_type_collapsed),
crit_infra_collapsed  = factor(crit_infra_collapsed),
supply_chain          = factor(supply_chain),
ransomware            = factor(ransomware)
)
}
if (!exists("train_data")) {
train_data <- read_csv("01_data/processed/dcid_train.csv", show_col_types = FALSE) %>% reload_factors()
test_data  <- read_csv("01_data/processed/dcid_test.csv",  show_col_types = FALSE) %>% reload_factors()
cat("Loaded train/test from CSV.\n")
}
dtree_full <- rpart(cyber_type ~ method_cat + obj_achievement + concession +
third_party + damage_type_collapsed + crit_infra_collapsed +
supply_chain + ransomware,
data = train_data,
method = "class",
control = rpart.control(cp = 0.001, minsplit = 10))
cat("\n===== FULL TREE =====\n")
print(dtree_full)
printcp(dtree_full)
# Find the cp value with the lowest cross-validated error
cp_table <- dtree_full$cptable
best_cp  <- cp_table[which.min(cp_table[, "xerror"]), "CP"]
# 1-SE rule: smallest tree within 1 SE of the minimum error
min_xerror <- min(cp_table[, "xerror"])
min_xstd   <- cp_table[which.min(cp_table[, "xerror"]), "xstd"]
cp_1se     <- cp_table[cp_table[, "xerror"] <= min_xerror + min_xstd, "CP"]
cp_1se     <- max(cp_1se)  # Largest cp (simplest tree) within 1 SE
cat(sprintf("\nBest cp (min error): %.5f\n", best_cp))
cat(sprintf("1-SE rule cp:        %.5f\n", cp_1se))
dtree_pruned <- prune(dtree_full, cp = cp_1se)
cat("\n===== PRUNED TREE =====\n")
print(dtree_pruned)
png("03_outputs/figures/model_diagnostics/decision_tree.png", width = 900, height = 600)
rpart.plot(dtree_pruned,
type = 4,
extra = 104,
fallen.leaves = TRUE,
main = "Decision Tree — Strategic vs. Tactical Cyber Activity",
box.palette = c("#E74C3C", "#2C3E50"))
dev.off()
# Variable importance
cat("\n--- Variable Importance ---\n")
vi_dtree <- dtree_pruned$variable.importance
print(sort(vi_dtree, decreasing = TRUE))
test_probs_dtree <- predict(dtree_pruned, newdata = test_data, type = "prob")[, "Strategic"]
test_pred_dtree  <- predict(dtree_pruned, newdata = test_data, type = "class")
cm_dtree <- confusionMatrix(test_pred_dtree, test_data$cyber_type,
positive = "Strategic")
cat("\n===== CONFUSION MATRIX =====\n")
print(cm_dtree)
roc_dtree <- roc(test_data$cyber_type, test_probs_dtree,
levels = c("Tactical", "Strategic"),
direction = "<")
cat(sprintf("\nAUC: %.4f\n", auc(roc_dtree)))
png("03_outputs/figures/model_diagnostics/roc_dtree.png", width = 600, height = 500)
plot(roc_dtree, main = "ROC Curve — Decision Tree",
col = "#27AE60", lwd = 2, print.auc = TRUE)
dev.off()
saveRDS(dtree_pruned, "03_outputs/models/dtree_model.rds")
dtree_results <- list(
model       = dtree_pruned,
predictions = test_pred_dtree,
probs       = test_probs_dtree,
confusion   = cm_dtree,
roc         = roc_dtree,
auc         = as.numeric(auc(roc_dtree)),
metrics     = data.frame(
Model     = "Decision Tree",
Accuracy  = cm_dtree$overall["Accuracy"],
Precision = cm_dtree$byClass["Precision"],
Recall    = cm_dtree$byClass["Recall"],
F1        = cm_dtree$byClass["F1"],
AUC       = as.numeric(auc(roc_dtree))
)
)
saveRDS(dtree_results, "03_outputs/models/dtree_results.rds")
cat("\nSaved: dtree_model.rds, dtree_results.rds\n")
cat("Script 06 complete.\n")
library(tidyverse)
library(caret)
library(randomForest)
library(pROC)
reload_factors <- function(df) {
df %>% mutate(
cyber_type            = factor(cyber_type, levels = c("Tactical", "Strategic")),
method_cat            = factor(method_cat),
obj_achievement       = factor(obj_achievement),
concession            = factor(concession),
third_party           = factor(third_party),
damage_type_collapsed = factor(damage_type_collapsed),
crit_infra_collapsed  = factor(crit_infra_collapsed),
supply_chain          = factor(supply_chain),
ransomware            = factor(ransomware)
)
}
if (!exists("train_data")) {
train_data <- read_csv("01_data/processed/dcid_train.csv", show_col_types = FALSE) %>% reload_factors()
test_data  <- read_csv("01_data/processed/dcid_test.csv",  show_col_types = FALSE) %>% reload_factors()
cat("Loaded train/test from CSV.\n")
}
set.seed(42)
rf_model <- randomForest(
cyber_type ~ method_cat + obj_achievement + concession +
third_party + damage_type_collapsed + crit_infra_collapsed +
supply_chain + ransomware,
data       = train_data,
ntree      = 500,
importance = TRUE
)
cat("\n===== RANDOM FOREST SUMMARY =====\n")
print(rf_model)
cat("\n--- Tuning mtry ---\n")
n_predictors <- 8
tuning_results <- data.frame(mtry = integer(), OOB_Error = numeric())
for (m in 1:n_predictors) {
set.seed(42)
rf_temp <- randomForest(
cyber_type ~ method_cat + obj_achievement + concession +
third_party + damage_type_collapsed + crit_infra_collapsed +
supply_chain + ransomware,
data  = train_data,
ntree = 500,
mtry  = m
)
oob_error <- rf_temp$err.rate[500, "OOB"]
tuning_results <- rbind(tuning_results, data.frame(mtry = m, OOB_Error = oob_error))
cat(sprintf("  mtry = %d: OOB error = %.4f\n", m, oob_error))
}
best_mtry <- tuning_results$mtry[which.min(tuning_results$OOB_Error)]
cat(sprintf("\nBest mtry: %d (OOB error: %.4f)\n", best_mtry,
min(tuning_results$OOB_Error)))
set.seed(42)
rf_model <- randomForest(
cyber_type ~ method_cat + obj_achievement + concession +
third_party + damage_type_collapsed + crit_infra_collapsed +
supply_chain + ransomware,
data       = train_data,
ntree      = 500,
mtry       = best_mtry,
importance = TRUE
)
cat("\n===== TUNED RANDOM FOREST =====\n")
print(rf_model)
cat("\n--- Variable Importance ---\n")
importance_df <- as.data.frame(importance(rf_model))
importance_df$Variable <- rownames(importance_df)
importance_df <- importance_df %>% arrange(desc(MeanDecreaseGini))
print(importance_df)
png("03_outputs/figures/model_diagnostics/rf_importance.png", width = 700, height = 500)
varImpPlot(rf_model, main = "Random Forest — Variable Importance")
dev.off()
test_pred_rf  <- predict(rf_model, newdata = test_data, type = "class")
test_probs_rf <- predict(rf_model, newdata = test_data, type = "prob")[, "Strategic"]
cm_rf <- confusionMatrix(test_pred_rf, test_data$cyber_type,
positive = "Strategic")
cat("\n===== CONFUSION MATRIX =====\n")
print(cm_rf)
roc_rf <- roc(test_data$cyber_type, test_probs_rf,
levels = c("Tactical", "Strategic"),
direction = "<")
cat(sprintf("\nAUC: %.4f\n", auc(roc_rf)))
png("03_outputs/figures/model_diagnostics/roc_rf.png", width = 600, height = 500)
plot(roc_rf, main = "ROC Curve — Random Forest",
col = "#E67E22", lwd = 2, print.auc = TRUE)
dev.off()
png("03_outputs/figures/model_diagnostics/rf_oob_error.png", width = 700, height = 500)
plot(rf_model, main = "Random Forest — OOB Error Rate by Number of Trees")
legend("topright", colnames(rf_model$err.rate), col = 1:3, lty = 1:3)
dev.off()
saveRDS(rf_model, "03_outputs/models/rf_model.rds")
rf_results <- list(
model       = rf_model,
predictions = test_pred_rf,
probs       = test_probs_rf,
confusion   = cm_rf,
roc         = roc_rf,
auc         = as.numeric(auc(roc_rf)),
best_mtry   = best_mtry,
metrics     = data.frame(
Model     = "Random Forest",
Accuracy  = cm_rf$overall["Accuracy"],
Precision = cm_rf$byClass["Precision"],
Recall    = cm_rf$byClass["Recall"],
F1        = cm_rf$byClass["F1"],
AUC       = as.numeric(auc(roc_rf))
)
)
saveRDS(rf_results, "03_outputs/models/rf_results.rds")
cat("\nSaved: rf_model.rds, rf_results.rds\n")
cat("Script 07 complete.\n")
library(tidyverse)
library(caret)
library(pROC)
logit_results <- readRDS("03_outputs/models/logit_results.rds")
dtree_results <- readRDS("03_outputs/models/dtree_results.rds")
rf_results    <- readRDS("03_outputs/models/rf_results.rds")
reload_factors <- function(df) {
df %>% mutate(
cyber_type            = factor(cyber_type, levels = c("Tactical", "Strategic")),
method_cat            = factor(method_cat),
obj_achievement       = factor(obj_achievement),
concession            = factor(concession),
third_party           = factor(third_party),
damage_type_collapsed = factor(damage_type_collapsed),
crit_infra_collapsed  = factor(crit_infra_collapsed),
supply_chain          = factor(supply_chain),
ransomware            = factor(ransomware)
)
}
test_data <- read_csv("01_data/processed/dcid_test.csv", show_col_types = FALSE) %>% reload_factors()
comparison <- bind_rows(
logit_results$metrics,
dtree_results$metrics,
rf_results$metrics
)
cat("\n===== MODEL COMPARISON =====\n")
print(comparison, digits = 4)
write_csv(comparison, "03_outputs/tables/model_comparison.csv")
png("03_outputs/figures/final_figures/roc_comparison.png", width = 700, height = 600)
plot(logit_results$roc, col = "#2C3E50", lwd = 2,
main = "ROC Curve Comparison — All Three Models")
plot(dtree_results$roc, col = "#27AE60", lwd = 2, add = TRUE)
plot(rf_results$roc,    col = "#E67E22", lwd = 2, add = TRUE)
abline(a = 0, b = 1, lty = 2, col = "gray50")
logit_results <- readRDS("03_outputs/models/logit_results.rds")
dtree_results <- readRDS("03_outputs/models/dtree_results.rds")
rf_results    <- readRDS("03_outputs/models/rf_results.rds")
reload_factors <- function(df) {
df %>% mutate(
cyber_type            = factor(cyber_type, levels = c("Tactical", "Strategic")),
method_cat            = factor(method_cat),
obj_achievement       = factor(obj_achievement),
concession            = factor(concession),
third_party           = factor(third_party),
damage_type_collapsed = factor(damage_type_collapsed),
crit_infra_collapsed  = factor(crit_infra_collapsed),
supply_chain          = factor(supply_chain),
ransomware            = factor(ransomware)
)
}
test_data <- read_csv("01_data/processed/dcid_test.csv", show_col_types = FALSE) %>% reload_factors()
test_data <- read_csv("01_data/02_processed/dcid_test.csv", show_col_types = FALSE) %>% reload_factors()
comparison <- bind_rows(
logit_results$metrics,
dtree_results$metrics,
rf_results$metrics
)
cat("\n===== MODEL COMPARISON =====\n")
print(comparison, digits = 4)
write_csv(comparison, "03_outputs/tables/model_comparison.csv")
png("03_outputs/figures/final_figures/roc_comparison.png", width = 700, height = 600)
plot(logit_results$roc, col = "#2C3E50", lwd = 2,
main = "ROC Curve Comparison — All Three Models")
png("03_outputs/figures/final_figures/roc_comparison.png", width = 700, height = 600)
plot(logit_results$roc, col = "#2C3E50", lwd = 2,
main = "ROC Curve Comparison — All Three Models")
plot(dtree_results$roc, col = "#27AE60", lwd = 2, add = TRUE)
plot(rf_results$roc,    col = "#E67E22", lwd = 2, add = TRUE)
abline(a = 0, b = 1, lty = 2, col = "gray50")
legend("bottomright",
legend = c(
sprintf("Logistic Regression (AUC = %.3f)", logit_results$auc),
sprintf("Decision Tree (AUC = %.3f)", dtree_results$auc),
sprintf("Random Forest (AUC = %.3f)", rf_results$auc)
),
col = c("#2C3E50", "#27AE60", "#E67E22"),
lwd = 2)
dev.off()
cat("\n===== CONFUSION MATRICES =====\n")
cat("\n--- Logistic Regression ---\n")
print(logit_results$confusion$table)
cat("\n--- Decision Tree ---\n")
print(dtree_results$confusion$table)
cat("\n--- Random Forest ---\n")
print(rf_results$confusion$table)
# Save confusion matrices
cm_summary <- data.frame(
Model = c("Logistic Regression", "Decision Tree", "Random Forest"),
TP = c(logit_results$confusion$table[2,2],
dtree_results$confusion$table[2,2],
rf_results$confusion$table[2,2]),
TN = c(logit_results$confusion$table[1,1],
dtree_results$confusion$table[1,1],
rf_results$confusion$table[1,1]),
FP = c(logit_results$confusion$table[2,1],
dtree_results$confusion$table[2,1],
rf_results$confusion$table[2,1]),
FN = c(logit_results$confusion$table[1,2],
dtree_results$confusion$table[1,2],
rf_results$confusion$table[1,2])
)
write_csv(cm_summary, "03_outputs/tables/cm_summary.csv")
cat("\n===== PAIRWISE MODEL COMPARISONS (McNemar's Test) =====\n")
logit_correct <- logit_results$predictions == test_data$cyber_type
dtree_correct <- dtree_results$predictions == test_data$cyber_type
rf_correct    <- rf_results$predictions    == test_data$cyber_type
cat("\n--- Logit vs Decision Tree ---\n")
mc_ld <- table(logit_correct, dtree_correct)
print(mc_ld)
tryCatch({
print(mcnemar.test(mc_ld))
}, error = function(e) cat("McNemar's test not applicable:", e$message, "\n"))
cat("\n--- Logit vs Random Forest ---\n")
mc_lr <- table(logit_correct, rf_correct)
print(mc_lr)
tryCatch({
print(mcnemar.test(mc_lr))
}, error = function(e) cat("McNemar's test not applicable:", e$message, "\n"))
cat("\n--- Decision Tree vs Random Forest ---\n")
mc_dr <- table(dtree_correct, rf_correct)
print(mc_dr)
tryCatch({
print(mcnemar.test(mc_dr))
}, error = function(e) cat("McNemar's test not applicable:", e$message, "\n"))
best_idx <- which.max(comparison$AUC)
cat(sprintf("\n===== RECOMMENDATION =====\n"))
cat(sprintf("Best model by AUC: %s (AUC = %.4f)\n",
comparison$Model[best_idx], comparison$AUC[best_idx]))
best_idx_f1 <- which.max(comparison$F1)
cat(sprintf("Best model by F1:  %s (F1 = %.4f)\n",
comparison$Model[best_idx_f1], comparison$F1[best_idx_f1]))
cat("\nScript 08 complete.\n")
cat("All modeling and comparison scripts finished.\n")
