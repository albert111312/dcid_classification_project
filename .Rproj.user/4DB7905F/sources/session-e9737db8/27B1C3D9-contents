# ============================================================================
# 4. CROSS-TABULATIONS WITH PREDICTORS
# ============================================================================

DV_FILL <- c("Tactical" = "#D3C3F2", "Strategic" = "#00B399")

# Print a labeled cross-tab of cyber_type x var.
print_crosstab <- function(var_name, var_label) {
  cat(sprintf("\n--- DV x %s ---\n", var_label))
  print(table(dcid$cyber_type, dcid[[var_name]]))
}

# Stacked-proportion plot: each category's bar is normalized to 1.0 and split
# by cyber_type. Used for predictors where relative class composition matters
# more than absolute counts (e.g., method, damage type).
plot_dv_proportion <- function(var_name, title, x_label, filename,
                               x_angle = 15, width = 7, height = 4) {
  p <- ggplot(dcid, aes(x = .data[[var_name]], fill = cyber_type)) +
    geom_bar(position = "fill") +
    scale_fill_manual(values = DV_FILL) +
    labs(title = title, x = x_label, y = "Proportion", fill = "Type") +
    theme_minimal() +
    theme(axis.text.x = element_text(angle = x_angle, hjust = 1))
  ggsave(filename, p, width = width, height = height)
}

# Horizontal stacked-count plot: categories ordered by total count, split by
# cyber_type. Used where absolute counts and rare-category visibility matter.
plot_dv_count <- function(var_name, title, x_label, filename,
                          width = 8, height = 6) {
  p <- dcid %>%
    count(.data[[var_name]], cyber_type) %>%
    ggplot(aes(x = reorder(.data[[var_name]], n), y = n, fill = cyber_type)) +
    geom_bar(stat = "identity", position = "stack") +
    scale_fill_manual(values = DV_FILL) +
    coord_flip() +
    labs(title = title, x = x_label, y = "Count", fill = "Type") +
    theme_minimal()
  ggsave(filename, p, width = width, height = height)
}

print_crosstab("method_cat",      "Method")
