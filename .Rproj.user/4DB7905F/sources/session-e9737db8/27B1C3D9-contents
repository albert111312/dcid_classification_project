# ============================================================================
# 5. DESCRIPTIVE STATISTICS TABLE
# ============================================================================

# Counts and percentages by class for each predictor level
desc_table <- dcid %>%
  group_by(cyber_type) %>%
  summarise(
    n = n(),
    method_vandalism      = sum(method_cat == "Vandalism"),
    method_ddos           = sum(method_cat == "DDoS"),
    method_intrusion      = sum(method_cat == "Network_Intrusion"),
    method_infiltration   = sum(method_cat == "Network_Infiltration"),
    obj_achieved_yes      = sum(obj_achievement == "Yes"),
    concession_yes        = sum(concession == "Yes"),
    third_party_yes       = sum(third_party == "Yes"),
    damage_dir_imm        = sum(damage_type == "Direct_Immediate"),
    damage_dir_del        = sum(damage_type == "Direct_Delayed"),
    damage_ind_imm        = sum(damage_type == "Indirect_Immediate"),
    damage_ind_del        = sum(damage_type == "Indirect_Delayed"),
    supply_chain_yes      = sum(supply_chain == "Yes"),
    ransomware_yes        = sum(ransomware == "Yes"),
    .groups = "drop"
  )

print(desc_table)
write_csv(desc_table, file.path(TABLES, "descriptive_stats.csv"))

desc <- desc_table %>%
  pivot_longer(cols = -cyber_type, names_to = "Variable", values_to = "Count") %>%
  pivot_wider(names_from = cyber_type, values_from = Count) %>%
  mutate(Variable = gsub("_", " ", Variable))

table_to_png(desc,
             "Descriptive Statistics by Cyber Activity Type",
             file.path(TABLES, "descriptive_stats.png"),
             col_widths = c(2.5, 1.2, 1.2))

